# Model provider — pick one
AI_PROVIDER=google          # google | openai | anthropic
AI_MODEL=                   # Optional: override default model (e.g. gpt-4o, claude-sonnet-4-20250514)
GEMINI_API_KEY=             # If AI_PROVIDER=google (default)
GOOGLE_GENERATIVE_AI_API_KEY=  # Same key — required by @ai-sdk/google
OPENAI_API_KEY=             # If AI_PROVIDER=openai
ANTHROPIC_API_KEY=          # If AI_PROVIDER=anthropic

# Moeba integration
MOEBA_WEBHOOK_SECRET=       # From Moeba admin dashboard
MOEBA_API_KEY=              # Agent API key (mba_...) — needed for proxy tools and proactive messaging
MOEBA_BASE_URL=https://moeba-api-999642860678.africa-south1.run.app

# Server
PORT=3001
